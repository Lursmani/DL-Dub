# Copy to .env and fill in. dub.py loads this automatically.

# ElevenLabs API key (Profile -> API Keys). Billed per CHARACTER synthesized.
ELEVENLABS_API_KEY=

# Anthropic API key for nl -> ka translation.
ANTHROPIC_API_KEY=

# HuggingFace token for speaker diarization (WhisperX / pyannote).
# You MUST also accept the model licenses once while logged in at:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
HF_TOKEN=
